# === LEX32069 — Variables de entorno ===

# Tu API Key de Google Gemini (obténla gratis en https://aistudio.google.com/apikey)
GEMINI_API_KEY=tu_key_aqui

# Carpeta donde están los PDFs de la ley y el reglamento
PDF_DIR=./docs

# (Opcional) Modelo de Gemini a usar. gemini-2.5-pro soporta 1M tokens de contexto.
# NOTA: gemini-2.5-pro y el contexto completo requieren BILLING activado en la API.
# Sin billing (free tier) solo funciona gemini-2.5-flash con MAX_CONTEXT_CHARS<=900000.
GEMINI_MODEL=gemini-2.5-pro

# (Opcional) Límite de caracteres del contexto inyectado a Gemini.
# Protege contra exceder el límite de tokens. ~4 chars = 1 token.
MAX_CONTEXT_CHARS=3500000
